# ===================================================================
# Agent harness
# ===================================================================
# Local (per-machine) Claude Code settings & state — shared settings stay tracked
.claude/settings.local.json
.claude/*.local.*
# Test runner output produced during verification
/TestResults/
# Working copy of the dev log PDF is tracked; intermediate converter artifacts are not
Docs/Reports/*.tex
Docs/Reports/*.log

# NOTE: The following are intentionally TRACKED — do not add them here:
#   CLAUDE.md, .claude/commands/, Docs/Agent/, Docs/Brief/, Docs/Reports/*.md, *.meta files
